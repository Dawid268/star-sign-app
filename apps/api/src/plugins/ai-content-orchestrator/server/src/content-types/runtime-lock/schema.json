{
  "kind": "collectionType",
  "collectionName": "aico_runtime_locks",
  "info": {
    "singularName": "runtime-lock",
    "pluralName": "runtime-locks",
    "displayName": "AICO Runtime Lock"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "lock_key": { "type": "uid", "required": true, "unique": true },
    "owner_id": { "type": "string", "required": true, "maxLength": 220 },
    "status": {
      "type": "enumeration",
      "enum": ["active", "released"],
      "default": "active"
    },
    "acquired_at": { "type": "datetime", "required": true },
    "expires_at": { "type": "datetime", "required": true },
    "released_at": { "type": "datetime" },
    "metadata": { "type": "json" }
  }
}
