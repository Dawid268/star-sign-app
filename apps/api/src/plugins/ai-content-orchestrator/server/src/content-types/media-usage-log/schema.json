{
  "kind": "collectionType",
  "collectionName": "aico_media_usage_logs",
  "info": {
    "singularName": "media-usage-log",
    "pluralName": "media-usage-logs",
    "displayName": "AICO Media Usage Log"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "content_uid": { "type": "string", "required": true },
    "content_entry_id": { "type": "integer", "required": true },
    "context_key": { "type": "string", "required": true },
    "used_at": { "type": "datetime", "required": true },
    "target_date": { "type": "date" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    },
    "media_asset": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.media-asset"
    }
  }
}
