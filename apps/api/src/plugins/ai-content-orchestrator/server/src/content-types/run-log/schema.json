{
  "kind": "collectionType",
  "collectionName": "aico_run_logs",
  "info": {
    "singularName": "run-log",
    "pluralName": "run-logs",
    "displayName": "AICO Run Log"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "run_type": {
      "type": "enumeration",
      "enum": ["generate", "publish", "manual", "backfill"],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["running", "success", "failed", "blocked_budget"],
      "required": true
    },
    "started_at": { "type": "datetime", "required": true },
    "finished_at": { "type": "datetime" },
    "attempts": { "type": "integer", "default": 1 },
    "error_message": { "type": "text" },
    "details": { "type": "json" },
    "usage_prompt_tokens": { "type": "integer", "default": 0 },
    "usage_completion_tokens": { "type": "integer", "default": 0 },
    "usage_total_tokens": { "type": "integer", "default": 0 },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    }
  }
}
