{
  "kind": "collectionType",
  "collectionName": "aico_media_assets",
  "info": {
    "singularName": "media-asset",
    "pluralName": "media-assets",
    "displayName": "AICO Media Asset"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "asset_key": { "type": "string", "required": true, "unique": true },
    "label": { "type": "string", "required": true },
    "purpose": {
      "type": "enumeration",
      "enum": ["horoscope_sign", "daily_card", "blog_article", "fallback_general"],
      "default": "blog_article"
    },
    "sign_slug": { "type": "string" },
    "period_scope": {
      "type": "enumeration",
      "enum": ["any", "daily", "weekly", "monthly"],
      "default": "any"
    },
    "keywords": { "type": "json" },
    "priority": { "type": "integer", "default": 0 },
    "active": { "type": "boolean", "default": true },
    "cooldown_days": { "type": "integer", "default": 3 },
    "last_used_at": { "type": "datetime" },
    "use_count": { "type": "integer", "default": 0 },
    "mapping_source": {
      "type": "enumeration",
      "enum": ["manual", "suggestion", "bulk_suggestion", "seed"]
    },
    "mapping_confidence": { "type": "float" },
    "mapping_reasons": { "type": "json" },
    "notes": { "type": "text" },
    "asset": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::upload.file"
    }
  }
}
