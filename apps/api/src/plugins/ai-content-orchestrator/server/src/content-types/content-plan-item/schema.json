{
  "kind": "collectionType",
  "collectionName": "aico_content_plan_items",
  "info": {
    "singularName": "content-plan-item",
    "pluralName": "content-plan-items",
    "displayName": "AICO Content Plan Item"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "title": { "type": "string", "required": true },
    "brief": { "type": "text" },
    "seo_intent": { "type": "string" },
    "seo_cluster": { "type": "string" },
    "priority_score": { "type": "integer", "default": 50 },
    "target_persona": { "type": "string" },
    "target_publish_at": { "type": "datetime" },
    "status": {
      "type": "enumeration",
      "enum": ["planned", "approved", "queued", "published", "rejected", "failed"],
      "default": "planned"
    },
    "channels": { "type": "json" },
    "agent_rationale": { "type": "text" },
    "source": {
      "type": "enumeration",
      "enum": ["strategy_agent", "manual", "performance_feedback"],
      "default": "strategy_agent"
    },
    "dedupe_key": { "type": "string" },
    "metadata": { "type": "json" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    },
    "article_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    },
    "generated_topic": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::ai-content-orchestrator.topic-queue-item"
    }
  }
}
