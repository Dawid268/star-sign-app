{
  "kind": "collectionType",
  "collectionName": "aico_homepage_recommendations",
  "info": {
    "singularName": "homepage-recommendation",
    "pluralName": "homepage-recommendations",
    "displayName": "AICO Homepage Recommendation"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "slot": {
      "type": "enumeration",
      "enum": ["today_in_stars", "weekly_focus", "recommended_for_you", "new_premium", "evergreen"],
      "required": true
    },
    "title": { "type": "string", "required": true },
    "subtitle": { "type": "text" },
    "target_url": { "type": "string" },
    "content_uid": { "type": "string" },
    "content_entry_id": { "type": "integer" },
    "content_slug": { "type": "string" },
    "priority_score": { "type": "integer", "default": 50 },
    "starts_at": { "type": "datetime" },
    "expires_at": { "type": "datetime" },
    "status": {
      "type": "enumeration",
      "enum": ["scheduled", "active", "expired", "archived"],
      "default": "active"
    },
    "rationale": { "type": "text" },
    "metadata": { "type": "json" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    },
    "source_snapshot": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.content-performance-snapshot"
    }
  }
}
