{
  "kind": "collectionType",
  "collectionName": "aico_publication_tickets",
  "info": {
    "singularName": "publication-ticket",
    "pluralName": "publication-tickets",
    "displayName": "AICO Publication Ticket"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "status": {
      "type": "enumeration",
      "enum": ["scheduled", "published", "failed", "canceled"],
      "default": "scheduled"
    },
    "business_key": { "type": "string", "required": true, "unique": true },
    "content_uid": { "type": "string", "required": true },
    "content_entry_id": { "type": "integer", "required": true },
    "target_publish_at": { "type": "datetime", "required": true },
    "published_on": { "type": "datetime" },
    "retries": { "type": "integer", "default": 0 },
    "last_error": { "type": "text" },
    "payload": { "type": "json" },
    "workflow": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.workflow"
    },
    "source_run": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::ai-content-orchestrator.run-log"
    }
  }
}
