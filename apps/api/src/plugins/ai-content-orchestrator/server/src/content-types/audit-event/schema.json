{
  "kind": "collectionType",
  "collectionName": "aico_audit_events",
  "info": {
    "singularName": "audit-event",
    "pluralName": "audit-events",
    "displayName": "AICO Audit Event"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "event_key": { "type": "uid", "required": true, "unique": true },
    "action": { "type": "string", "required": true, "maxLength": 160 },
    "outcome": {
      "type": "enumeration",
      "enum": ["success", "failure", "skipped"],
      "required": true
    },
    "severity": {
      "type": "enumeration",
      "enum": ["info", "warn", "error"],
      "default": "info"
    },
    "occurred_at": { "type": "datetime", "required": true },
    "actor_type": {
      "type": "enumeration",
      "enum": ["admin", "system", "unknown"],
      "default": "unknown"
    },
    "actor_id": { "type": "string", "maxLength": 120 },
    "resource_uid": { "type": "string", "maxLength": 180 },
    "resource_id": { "type": "string", "maxLength": 120 },
    "resource_label": { "type": "string", "maxLength": 220 },
    "request_id": { "type": "string", "maxLength": 160 },
    "ip_hash": { "type": "string", "maxLength": 128, "private": true },
    "metadata": { "type": "json" }
  }
}
