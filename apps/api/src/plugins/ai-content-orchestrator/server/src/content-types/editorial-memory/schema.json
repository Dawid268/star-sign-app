{
  "kind": "collectionType",
  "collectionName": "aico_editorial_memories",
  "info": {
    "singularName": "editorial-memory",
    "pluralName": "editorial-memories",
    "displayName": "AICO Editorial Memory"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": true },
    "content-type-builder": { "visible": true }
  },
  "attributes": {
    "key": { "type": "string", "required": true, "unique": true },
    "label": { "type": "string", "required": true },
    "memory_type": {
      "type": "enumeration",
      "enum": ["brand_voice", "seo_rule", "persona", "prohibited_phrase", "linking_rule", "custom"],
      "default": "custom"
    },
    "content": { "type": "text", "required": true },
    "active": { "type": "boolean", "default": true },
    "priority": { "type": "integer", "default": 0 },
    "metadata": { "type": "json" }
  }
}
