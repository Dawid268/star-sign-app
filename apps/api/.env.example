# API-only local template. Use the repository root .env.example for Docker Compose production.

HOST=0.0.0.0
PORT=1337
NODE_ENV=development

APP_KEYS=dev_key_1,dev_key_2,dev_key_3,dev_key_4
API_TOKEN_SALT=dev_api_token_salt
ADMIN_JWT_SECRET=dev_admin_jwt_secret
TRANSFER_TOKEN_SALT=dev_transfer_token_salt
JWT_SECRET=dev_jwt_secret
ENCRYPTION_KEY=dev_encryption_key_32_chars_minimum

DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
FRONTEND_URL=http://localhost:4200
SHOP_ENABLED=false

BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
BREVO_FROM_EMAIL=Star Sign <noreply@starsign.local>
BREVO_REPLY_TO=kontakt@starsign.local
NEWSLETTER_DOUBLE_OPT_IN=true
BREVO_WEBHOOK_SECRET=dev_newsletter_webhook_secret

R2_UPLOAD_ENABLED=false
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

AICO_OPENROUTER_TOKEN=
AICO_OPENROUTER_MODEL=openai/gpt-4.1-mini
AICO_ENABLE_WORKFLOWS=false

SENTRY_DSN=
STRAPI_DOCUMENTATION_ENABLED=true
STRAPI_SEO_PLUGIN_ENABLED=true
