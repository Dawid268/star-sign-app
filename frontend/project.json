{
  "name": "frontend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "frontend/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/frontend",
        "index": "frontend/src/index.html",
        "browser": "frontend/src/main.ts",
        "server": "frontend/src/main.server.ts",
        "ssr": {
          "entry": "frontend/src/server.ts"
        },
        "outputMode": "server",
        "tsConfig": "frontend/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "frontend/public"
          }
        ],
        "styles": ["frontend/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "serviceWorker": "frontend/ngsw-config.json",
          "sourceMap": {
            "scripts": true,
            "styles": false,
            "hidden": true,
            "vendor": false,
            "sourcesContent": true
          },
          "namedChunks": false,
          "extractLicenses": true,
          "fileReplacements": [
            {
              "replace": "frontend/src/environments/environment.ts",
              "with": "frontend/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "frontend/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "frontend:build:production"
        },
        "development": {
          "buildTarget": "frontend:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {},
      "configurations": {
        "coverage": {
          "coverage": true,
          "coverageExclude": ["libs/frontend/cart/**"],
          "coverageReporters": ["text", "html", "lcov", "json-summary"],
          "coverageThresholds": {
            "statements": 85,
            "lines": 85,
            "branches": 75,
            "functions": 75
          }
        }
      }
    },
    "serve-static": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx build frontend",
          "cp dist/frontend/browser/index.csr.html dist/frontend/browser/index.html",
          "node proxy-server.mjs"
        ],
        "parallel": false
      }
    }
  }
}
