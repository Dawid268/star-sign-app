{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/frontend/cart",
    "rootDir": "src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/frontend/cart/tsconfig.lib.tsbuildinfo",
    "types": []
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../../shared/types/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test-setup.ts"
  ]
}
